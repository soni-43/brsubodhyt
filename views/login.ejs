<%- include('partials/head') %>

<div class="auth-container">
  <div class="auth-card">
    <div class="text-center mb-3">
      <div class="brand-icon mx-auto mb-3" style="width:56px;height:56px;font-size:28px;border-radius:16px;">
        <i class="bi bi-lightning-charge-fill"></i>
      </div>
    </div>
    <h1 class="auth-title">Welcome Back</h1>
    <p class="auth-subtitle">Login to your account</p>
    
    <% if (error) { %>
      <div class="alert alert-danger py-2" style="font-size:13px;background:#ef444422;border-color:#ef444444;color:#ef4444;"><%= error %></div>
    <% } %>
    
    <% if (typeof otpRequired !== 'undefined' && otpRequired) { %>
      <!-- OTP Verification Step -->
      <form method="POST" action="/login">
        <input type="hidden" name="username" value="<%= username %>">
        <input type="hidden" name="password" value="<%= password %>">
        <div class="mb-3">
          <label class="form-label">OTP sent to <%= mobile %></label>
          <input type="text" name="otp" class="form-control form-input" placeholder="Enter 6-digit OTP" maxlength="6" required>
        </div>
        <button type="submit" class="btn btn-accent w-100 mb-3">
          <i class="bi bi-shield-check me-2"></i>Verify OTP
        </button>
      </form>
    <% } else { %>
      <form method="POST" action="/login">
        <div class="mb-3">
          <label class="form-label">Username or Email</label>
          <input type="text" name="username" class="form-control form-input" placeholder="Enter username or email" required>
        </div>
        <div class="mb-4">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control form-input" placeholder="Enter password" required>
        </div>
        <button type="submit" class="btn btn-accent w-100 mb-3">
          <i class="bi bi-box-arrow-in-right me-2"></i>Login
        </button>
      </form>
    <% } %>
    
    <p class="text-center" style="font-size:13px;color:var(--text-secondary);">
      Don't have an account? <a href="/register" style="color:var(--accent);">Register</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
