<%- include('partials/head') %>

<div class="section-header">
  <h2 class="section-title"><i class="bi bi-box-seam me-2"></i>API History</h2>
</div>

<% if (purchases.length === 0) { %>
  <div class="empty-state"><i class="bi bi-box-seam"></i><p>No APIs purchased yet</p></div>
<% } else { %>
  <% purchases.forEach(p => { %>
  <div class="glass-card mb-3">
    <div class="d-flex justify-content-between align-items-start mb-2">
      <div>
        <h6 style="font-family:var(--font-display);font-weight:600;margin:0;"><%= p.api_name %></h6>
        <small style="color:var(--text-muted);"><%= p.category %></small>
      </div>
      <span class="badge-status badge-<%= p.status %>">
        <% if (p.status === 'waiting') { %>Pending Activation<% } %>
        <% if (p.status === 'activated') { %>Activated<% } %>
        <% if (p.status === 'rejected') { %>Rejected<% } %>
      </span>
    </div>
    <div class="d-flex justify-content-between align-items-center">
      <span style="color:var(--accent);font-weight:600;">&#8377;<%= parseFloat(p.price).toFixed(2) %></span>
      <small style="color:var(--text-muted);"><%= new Date(p.created_at).toLocaleDateString('en-IN') %></small>
    </div>
    <% if (p.status === 'activated' && p.api_details) { %>
    <div class="mt-3 p-3" style="background:var(--bg-input);border-radius:var(--radius-xs);border:1px solid var(--border-color);">
      <small style="color:var(--text-muted);display:block;margin-bottom:4px;">API Details:</small>
      <pre style="color:var(--accent);font-size:12px;margin:0;white-space:pre-wrap;word-break:break-all;"><%= p.api_details %></pre>
    </div>
    <% } %>
    <% if (p.status === 'rejected' && p.rejection_reason) { %>
    <div class="mt-3 p-3" style="background:#ef444411;border-radius:var(--radius-xs);border:1px solid #ef444433;">
      <small style="color:var(--danger);display:block;margin-bottom:4px;">Rejection Reason:</small>
      <p style="color:var(--text-secondary);font-size:12px;margin:0;"><%= p.rejection_reason %></p>
    </div>
    <% } %>
  </div>
  <% }) %>
<% } %>

<%- include('partials/footer') %>
