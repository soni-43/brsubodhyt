<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | BR SUBODH YT Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <!-- Mobile Toggle -->
  <button class="admin-toggle"><i class="bi bi-list"></i></button>
  
  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="admin-sidebar-header">
      <div class="header-brand">
        <div class="brand-icon"><i class="bi bi-lightning-charge-fill"></i></div>
        <span class="brand-text">Admin Panel</span>
      </div>
    </div>
    <nav class="admin-sidebar-nav">
      <a href="/admin" class="admin-nav-item <%= title === 'Admin Dashboard' ? 'active' : '' %>">
        <i class="bi bi-grid-1x2-fill"></i> Dashboard
      </a>
      <a href="/admin/users" class="admin-nav-item <%= title === 'User Management' ? 'active' : '' %>">
        <i class="bi bi-people-fill"></i> Users
      </a>
      <a href="/admin/deposits" class="admin-nav-item <%= title === 'Deposit Management' ? 'active' : '' %>">
        <i class="bi bi-wallet2"></i> Deposits
      </a>
      <a href="/admin/apis" class="admin-nav-item <%= title === 'API Management' ? 'active' : '' %>">
        <i class="bi bi-box-seam-fill"></i> APIs
      </a>
      <a href="/admin/activations" class="admin-nav-item <%= title === 'API Activations' ? 'active' : '' %>">
        <i class="bi bi-lightning-fill"></i> Activations
      </a>
      <a href="/admin/feedback" class="admin-nav-item <%= title === 'Feedback Management' ? 'active' : '' %>">
        <i class="bi bi-chat-heart-fill"></i> Feedback
      </a>
      <a href="/admin/settings" class="admin-nav-item <%= title === 'Settings' ? 'active' : '' %>">
        <i class="bi bi-gear-fill"></i> Settings
      </a>
      <hr style="border-color:var(--border-color);margin:12px 0;">
      <a href="/" class="admin-nav-item">
        <i class="bi bi-house"></i> View Site
      </a>
      <a href="/admin/logout" class="admin-nav-item" style="color:var(--danger);">
        <i class="bi bi-box-arrow-right"></i> Logout
      </a>
    </nav>
  </aside>
  
  <!-- Main Content -->
  <div class="admin-main">
    <div class="admin-topbar">
      <h1 class="admin-page-title"><%= title %></h1>
    </div>
    <%- body %>
  </div>
  
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
