<%- include('../partials/head') %>
<%- include('../partials/admin-sidebar') %>

<div class="admin-main">
  <div class="admin-topbar">
    <h1 class="admin-page-title">User Management</h1>
  </div>

  <div class="admin-table-wrap">
    <div style="overflow-x:auto;">
      <table class="table">
        <thead>
          <tr><th>ID</th><th>Username</th><th>Name</th><th>Mobile</th><th>Email</th><th>API Addr</th><th>Balance</th><th>Joined</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
          <tr>
            <td>#<%= u.id %></td>
            <td><strong><%= u.username %></strong></td>
            <td><%= u.full_name %></td>
            <td><%= u.mobile || '—' %></td>
            <td><%= u.email %></td>
            <td style="font-size:11px;"><%= u.api_address %></td>
            <td style="color:var(--accent);font-weight:600;">₹<%= parseFloat(u.balance).toFixed(2) %></td>
            <td><%= new Date(u.created_at).toLocaleDateString('en-IN') %></td>
            <td>
              <div class="d-flex gap-1 flex-wrap">
                <form method="POST" action="/admin/users/<%= u.id %>/balance" style="display:inline;">
                  <input type="hidden" name="action" value="add"><input type="hidden" name="amount" value="100">
                  <button type="submit" class="btn-action btn-action-approve" title="Add ₹100"><i class="bi bi-plus"></i></button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/balance" style="display:inline;">
                  <input type="hidden" name="action" value="deduct"><input type="hidden" name="amount" value="100">
                  <button type="submit" class="btn-action btn-action-edit" title="Deduct ₹100"><i class="bi bi-dash"></i></button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/ban" style="display:inline;">
                  <button type="submit" class="btn-action" style="background:#f59e0b22;color:var(--warning);" title="<%= u.is_banned ? 'Unban' : 'Ban' %>">
                    <i class="bi bi-<%= u.is_banned ? 'unlock' : 'ban' %>"></i>
                  </button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this user?');">
                  <button type="submit" class="btn-action btn-action-delete" title="Delete"><i class="bi bi-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (users.length === 0) { %>
          <tr><td colspan="9" style="text-align:center;padding:32px;color:var(--text-muted);">No users yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
