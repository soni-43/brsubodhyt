<%- include('../partials/head') %>
<%- include('../partials/admin-sidebar') %>

<div class="admin-main">
  <div class="admin-topbar">
    <h1 class="admin-page-title">API Management</h1>
    <button class="btn btn-accent btn-sm" data-bs-toggle="modal" data-bs-target="#addApiModal"><i class="bi bi-plus-lg me-1"></i>Add API</button>
  </div>

  <div class="admin-table-wrap">
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr><th>ID</th><th>Title</th><th>Category</th><th>Price</th><th>Label</th><th>Stock</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% apis.forEach(api => { %>
          <tr>
            <td>#<%= api.id %></td>
            <td><strong><%= api.title %></strong></td>
            <td><%= api.category %></td>
            <td style="color:var(--accent);font-weight:600;">₹<%= parseFloat(api.price).toFixed(0) %></td>
            <td><span class="api-label label-<%= api.label.toLowerCase().replace(/[^a-z0-9]/g, '') %>"><%= api.label %></span></td>
            <td><%= api.available_quantity %>/<%= api.total_quantity %></td>
            <td><span class="badge-status <%= api.is_active ? 'badge-approved' : 'badge-rejected' %>"><%= api.is_active ? 'Active' : 'Inactive' %></span></td>
            <td>
              <div class="d-flex gap-1">
                <button class="btn-action btn-action-edit" data-bs-toggle="modal" data-bs-target="#editApi<%= api.id %>" title="Edit"><i class="bi bi-pencil"></i></button>
                <form method="POST" action="/admin/apis/<%= api.id %>/toggle" style="display:inline;">
                  <button type="submit" class="btn-action" style="background:#f59e0b22;color:var(--warning);" title="Toggle"><i class="bi bi-power"></i></button>
                </form>
                <form method="POST" action="/admin/apis/<%= api.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete?');">
                  <button type="submit" class="btn-action btn-action-delete" title="Delete"><i class="bi bi-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
          <!-- Edit Modal -->
          <div class="modal fade" id="editApi<%= api.id %>" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered modal-lg">
              <div class="modal-content glass-card">
                <form method="POST" action="/admin/apis/<%= api.id %>/edit">
                  <div class="modal-header border-0"><h5 class="modal-title">Edit: <%= api.title %></h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                  <div class="modal-body">
                    <div class="row g-3">
                      <div class="col-md-6"><label class="form-label">Title</label><input type="text" name="title" class="form-control form-input" value="<%= api.title %>" required></div>
                      <div class="col-md-6"><label class="form-label">Category</label><input type="text" name="category" class="form-control form-input" value="<%= api.category %>" required></div>
                      <div class="col-md-4"><label class="form-label">Price</label><input type="number" name="price" class="form-control form-input" value="<%= api.price %>" step="0.01" required></div>
                      <div class="col-md-4"><label class="form-label">Label</label>
                        <select name="label" class="form-control form-input">
                          <% ['Guaranteed 100%','Premium','Random','50/50','VIP'].forEach(l => { %>
                          <option value="<%= l %>" <%= api.label === l ? 'selected' : '' %>><%= l %></option>
                          <% }) %>
                        </select>
                      </div>
                      <div class="col-md-4"><label class="form-label">Quantity</label><input type="number" name="total_quantity" class="form-control form-input" value="<%= api.total_quantity %>" required></div>
                      <div class="col-12"><label class="form-label">Description</label><textarea name="description" class="form-control form-input" rows="2"><%= api.description %></textarea></div>
                      <div class="col-12"><label class="form-label">API Details</label><textarea name="api_details" class="form-control form-input" rows="3"><%= api.api_details || '' %></textarea></div>
                    </div>
                  </div>
                  <div class="modal-footer border-0"><button type="button" class="btn btn-outline-accent" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-accent">Save</button></div>
                </form>
              </div>
            </div>
          </div>
          <% }) %>
          <% if (apis.length === 0) { %>
          <tr><td colspan="8" style="text-align:center;padding:32px;color:var(--text-muted);">No APIs</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add API Modal -->
<div class="modal fade" id="addApiModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content glass-card">
      <form method="POST" action="/admin/apis/add">
        <div class="modal-header border-0"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Add API</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Title</label><input type="text" name="title" class="form-control form-input" required></div>
            <div class="col-md-6"><label class="form-label">Category</label><input type="text" name="category" class="form-control form-input" required></div>
            <div class="col-md-4"><label class="form-label">Price</label><input type="number" name="price" class="form-control form-input" step="0.01" required></div>
            <div class="col-md-4"><label class="form-label">Label</label>
              <select name="label" class="form-control form-input">
                <option>Random</option><option>Guaranteed 100%</option><option>Premium</option><option>50/50</option><option>VIP</option>
              </select>
            </div>
            <div class="col-md-4"><label class="form-label">Quantity</label><input type="number" name="total_quantity" class="form-control form-input" required></div>
            <div class="col-12"><label class="form-label">Description</label><textarea name="description" class="form-control form-input" rows="2"></textarea></div>
            <div class="col-12"><label class="form-label">API Details</label><textarea name="api_details" class="form-control form-input" rows="3"></textarea></div>
          </div>
        </div>
        <div class="modal-footer border-0"><button type="button" class="btn btn-outline-accent" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-accent">Add API</button></div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
