<%- include('../partials/head') %>
<%- include('../partials/admin-sidebar') %>

<div class="admin-main">
  <div class="admin-topbar"><h1 class="admin-page-title">Feedback Management</h1></div>

  <div class="admin-table-wrap">
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr><th>ID</th><th>User</th><th>Type</th><th>Name</th><th>Rating</th><th>Message</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% feedbacks.forEach(f => { %>
          <tr style="<%= f.is_hidden ? 'opacity:0.5;' : '' %>">
            <td>#<%= f.id %></td>
            <td><%= f.username %></td>
            <td><span class="badge-status badge-pending"><%= f.type %></span></td>
            <td><strong><%= f.name %></strong></td>
            <td style="color:var(--gold);"><% for(let i=0;i<f.rating;i++){ %><i class="bi bi-star-fill"></i><% } %></td>
            <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= f.message %></td>
            <td>
              <span class="badge-status badge-<%= f.status %>"><%= f.status.toUpperCase() %></span>
              <% if (f.is_hidden) { %><br><small style="color:var(--warning);">HIDDEN</small><% } %>
            </td>
            <td>
              <div class="d-flex gap-1">
                <% if (f.status !== 'approved') { %>
                <form method="POST" action="/admin/feedback/<%= f.id %>/approve" style="display:inline;">
                  <button type="submit" class="btn-action btn-action-approve" title="Approve"><i class="bi bi-check-lg"></i></button>
                </form>
                <% } %>
                <% if (f.status !== 'rejected') { %>
                <form method="POST" action="/admin/feedback/<%= f.id %>/reject" style="display:inline;">
                  <button type="submit" class="btn-action" style="background:#f59e0b22;color:var(--warning);" title="Reject"><i class="bi bi-eye-slash"></i></button>
                </form>
                <% } %>
                <form method="POST" action="/admin/feedback/<%= f.id %>/hide" style="display:inline;">
                  <button type="submit" class="btn-action btn-action-edit" title="<%= f.is_hidden ? 'Show' : 'Hide' %>"><i class="bi bi-<%= f.is_hidden ? 'eye' : 'eye-slash' %>"></i></button>
                </form>
                <form method="POST" action="/admin/feedback/<%= f.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete?');">
                  <button type="submit" class="btn-action btn-action-delete" title="Delete"><i class="bi bi-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (feedbacks.length === 0) { %>
          <tr><td colspan="8" style="text-align:center;padding:32px;color:var(--text-muted);">No feedback</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
