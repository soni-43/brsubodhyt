<%- include('../partials/head') %>
<%- include('../partials/admin-sidebar') %>

<div class="admin-main">
  <div class="admin-topbar">
    <h1 class="admin-page-title">Social Tasks</h1>
    <button class="btn btn-accent btn-sm" data-bs-toggle="modal" data-bs-target="#addTaskModal"><i class="bi bi-plus-lg me-1"></i>Add Task</button>
  </div>

  <!-- Tasks List -->
  <div class="admin-table-wrap mb-4">
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr><th>ID</th><th>Platform</th><th>Task</th><th>Reward</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% tasks.forEach(t => { %>
          <tr>
            <td>#<%= t.id %></td>
            <td><i class="bi bi-<%= t.platform === 'Telegram' ? 'telegram' : t.platform === 'YouTube' ? 'youtube' : t.platform === 'Instagram' ? 'instagram' : t.platform === 'WhatsApp' ? 'whatsapp' : t.platform === 'Facebook' ? 'facebook' : 'twitter-x' %>"></i> <%= t.platform %></td>
            <td><%= t.task_name %></td>
            <td style="color:var(--gold);font-weight:600;">₹<%= parseFloat(t.reward).toFixed(0) %></td>
            <td><span class="badge-status <%= t.is_active ? 'badge-approved' : 'badge-rejected' %>"><%= t.is_active ? 'Active' : 'Inactive' %></span></td>
            <td>
              <div class="d-flex gap-1">
                <form method="POST" action="/admin/tasks/<%= t.id %>/toggle" style="display:inline;">
                  <button type="submit" class="btn-action" style="background:#f59e0b22;color:var(--warning);"><i class="bi bi-power"></i></button>
                </form>
                <form method="POST" action="/admin/tasks/<%= t.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete?');">
                  <button type="submit" class="btn-action btn-action-delete"><i class="bi bi-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (tasks.length === 0) { %>
          <tr><td colspan="6" style="text-align:center;padding:32px;color:var(--text-muted);">No tasks</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Completions -->
  <h5 style="font-family:var(--font-display);font-weight:600;margin-bottom:12px;">Task Completions</h5>
  <div class="admin-table-wrap">
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr><th>ID</th><th>User</th><th>Task</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% completions.forEach(c => { %>
          <tr>
            <td>#<%= c.id %></td>
            <td><%= c.username %></td>
            <td><%= c.task_name %></td>
            <td><%= new Date(c.created_at).toLocaleDateString('en-IN') %></td>
            <td><span class="badge-status badge-<%= c.status === 'verified' ? 'approved' : c.status === 'rejected' ? 'rejected' : 'pending' %>"><%= c.status.toUpperCase() %></span></td>
            <td>
              <% if (c.status === 'pending') { %>
              <div class="d-flex gap-1">
                <form method="POST" action="/admin/tasks/complete/<%= c.id %>/verify" style="display:inline;">
                  <button type="submit" class="btn-action btn-action-approve" title="Verify"><i class="bi bi-check-lg"></i></button>
                </form>
                <form method="POST" action="/admin/tasks/complete/<%= c.id %>/reject" style="display:inline;">
                  <button type="submit" class="btn-action btn-action-reject" title="Reject"><i class="bi bi-x-lg"></i></button>
                </form>
              </div>
              <% } else { %><span style="color:var(--text-muted);">—</span><% } %>
            </td>
          </tr>
          <% }) %>
          <% if (completions.length === 0) { %>
          <tr><td colspan="6" style="text-align:center;padding:32px;color:var(--text-muted);">No completions</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Task Modal -->
<div class="modal fade" id="addTaskModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content glass-card">
      <form method="POST" action="/admin/tasks/add">
        <div class="modal-header border-0"><h5 class="modal-title">Add Task</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="mb-3"><label class="form-label">Platform</label>
            <select name="platform" class="form-control form-input">
              <option>Telegram</option><option>WhatsApp</option><option>YouTube</option><option>Instagram</option><option>Facebook</option><option>Twitter/X</option>
            </select>
          </div>
          <div class="mb-3"><label class="form-label">Task Name</label><input type="text" name="task_name" class="form-control form-input" placeholder="e.g. Follow our channel" required></div>
          <div class="mb-3"><label class="form-label">Task URL</label><input type="text" name="task_url" class="form-control form-input" placeholder="https://..." required></div>
          <div class="mb-3"><label class="form-label">Reward (₹)</label><input type="number" name="reward" class="form-control form-input" placeholder="10" step="0.01" required></div>
        </div>
        <div class="modal-footer border-0"><button type="button" class="btn btn-outline-accent" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-accent">Add Task</button></div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
