<%- include('../partials/head') %>
<%- include('../partials/admin-sidebar') %>

<div class="admin-main">
  <div class="admin-topbar">
    <h1 class="admin-page-title">API Activations</h1>
  </div>

  <div class="admin-table-wrap">
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr><th>ID</th><th>User</th><th>API</th><th>Price</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% purchases.forEach(p => { %>
          <tr>
            <td>#<%= p.id %></td>
            <td><strong><%= p.username %></strong></td>
            <td><%= p.api_name %></td>
            <td style="color:var(--accent);">₹<%= parseFloat(p.price).toFixed(2) %></td>
            <td><%= new Date(p.created_at).toLocaleDateString('en-IN') %></td>
            <td><span class="badge-status badge-<%= p.status %>"><%= p.status === 'waiting' ? 'Waiting' : p.status === 'activated' ? 'Activated' : 'Rejected' %></span></td>
            <td>
              <% if (p.status === 'waiting') { %>
              <div class="d-flex gap-1">
                <form method="POST" action="/admin/activations/<%= p.id %>/activate" style="display:inline;">
                  <button type="submit" class="btn-action btn-action-approve" title="Activate"><i class="bi bi-check-lg"></i></button>
                </form>
                <button class="btn-action btn-action-reject" data-bs-toggle="modal" data-bs-target="#rejectModal<%= p.id %>" title="Reject"><i class="bi bi-x-lg"></i></button>
              </div>
              <!-- Reject Modal -->
              <div class="modal fade" id="rejectModal<%= p.id %>" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                  <div class="modal-content glass-card">
                    <form method="POST" action="/admin/activations/<%= p.id %>/reject">
                      <div class="modal-header border-0"><h5 class="modal-title">Reject Purchase #<%= p.id %></h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                      <div class="modal-body">
                        <label class="form-label">Rejection Reason</label>
                        <textarea name="reason" class="form-control form-input" rows="3" placeholder="Reason for rejection..." required></textarea>
                      </div>
                      <div class="modal-footer border-0"><button type="button" class="btn btn-outline-accent" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn" style="background:var(--danger);color:#fff;">Reject & Refund</button></div>
                    </form>
                  </div>
                </div>
              </div>
              <% } else { %><span style="color:var(--text-muted);">—</span><% } %>
            </td>
          </tr>
          <% }) %>
          <% if (purchases.length === 0) { %>
          <tr><td colspan="7" style="text-align:center;padding:32px;color:var(--text-muted);">No activation requests</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
