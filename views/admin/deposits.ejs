<%- include('../partials/head') %>
<%- include('../partials/admin-sidebar') %>

<div class="admin-main">
  <div class="admin-topbar">
    <h1 class="admin-page-title">Deposit Management</h1>
  </div>

  <div class="admin-table-wrap">
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr><th>ID</th><th>User</th><th>Amount</th><th>UTR</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% deposits.forEach(d => { %>
          <tr>
            <td>#<%= d.id %></td>
            <td><strong><%= d.username %></strong></td>
            <td style="color:var(--accent);font-weight:600;">₹<%= parseFloat(d.amount).toFixed(2) %></td>
            <td><code style="color:var(--text-secondary);font-size:12px;"><%= d.transaction_id %></code></td>
            <td><%= new Date(d.created_at).toLocaleDateString('en-IN') %></td>
            <td><span class="badge-status badge-<%= d.status %>"><%= d.status.toUpperCase() %></span></td>
            <td>
              <% if (d.status === 'pending') { %>
              <div class="d-flex gap-1">
                <form method="POST" action="/admin/deposits/<%= d.id %>/approve" style="display:inline;">
                  <button type="submit" class="btn-action btn-action-approve" title="Approve"><i class="bi bi-check-lg"></i></button>
                </form>
                <form method="POST" action="/admin/deposits/<%= d.id %>/reject" style="display:inline;">
                  <button type="submit" class="btn-action btn-action-reject" title="Reject"><i class="bi bi-x-lg"></i></button>
                </form>
              </div>
              <% } else { %><span style="color:var(--text-muted);font-size:12px;">—</span><% } %>
            </td>
          </tr>
          <% }) %>
          <% if (deposits.length === 0) { %>
          <tr><td colspan="7" style="text-align:center;padding:32px;color:var(--text-muted);">No deposit requests</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
