<%- include('../partials/head') %>
<%- include('../partials/admin-sidebar') %>

<div class="admin-main">
  <div class="admin-topbar"><h1 class="admin-page-title">Activity Logs</h1></div>

  <div class="admin-table-wrap">
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr><th>ID</th><th>Admin</th><th>Action</th><th>Details</th><th>IP</th><th>Time</th></tr></thead>
        <tbody>
          <% logs.forEach(l => { %>
          <tr>
            <td>#<%= l.id %></td>
            <td><strong><%= l.username %></strong></td>
            <td><span class="badge-status badge-pending"><%= l.action %></span></td>
            <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= l.details || '—' %></td>
            <td style="font-size:12px;color:var(--text-muted);"><%= l.ip_address || '—' %></td>
            <td><%= new Date(l.created_at).toLocaleString('en-IN') %></td>
          </tr>
          <% }) %>
          <% if (logs.length === 0) { %>
          <tr><td colspan="6" style="text-align:center;padding:32px;color:var(--text-muted);">No logs</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
