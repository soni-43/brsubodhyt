<%- include('../partials/head') %>

<button class="admin-toggle" onclick="document.querySelector('.admin-sidebar').classList.toggle('open')"><i class="bi bi-list"></i></button>

<aside class="admin-sidebar">
  <div class="admin-sidebar-header">
    <div class="header-brand"><div class="brand-icon"><i class="bi bi-lightning-charge-fill"></i></div><span class="brand-text">Admin Panel</span></div>
  </div>
  <nav class="admin-sidebar-nav">
    <a href="/admin" class="admin-nav-item active"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
    <a href="/admin/users" class="admin-nav-item"><i class="bi bi-people-fill"></i> Users</a>
    <a href="/admin/deposits" class="admin-nav-item"><i class="bi bi-wallet2"></i> Deposits</a>
    <a href="/admin/apis" class="admin-nav-item"><i class="bi bi-box-seam-fill"></i> APIs</a>
    <a href="/admin/activations" class="admin-nav-item"><i class="bi bi-lightning-fill"></i> Activations</a>
    <a href="/admin/feedback" class="admin-nav-item"><i class="bi bi-chat-heart-fill"></i> Feedback</a>
    <a href="/admin/tasks" class="admin-nav-item"><i class="bi bi-trophy-fill"></i> Tasks</a>
    <a href="/admin/policies" class="admin-nav-item"><i class="bi bi-file-text-fill"></i> Policies</a>
    <a href="/admin/settings" class="admin-nav-item"><i class="bi bi-gear-fill"></i> Settings</a>
    <a href="/admin/logs" class="admin-nav-item"><i class="bi bi-journal-text"></i> Logs</a>
    <% if (isSuperAdmin) { %>
    <a href="/admin/admins" class="admin-nav-item"><i class="bi bi-shield-fill-check"></i> Admins</a>
    <% } %>
    <hr style="border-color:var(--border-color);margin:12px 0;">
    <a href="/" class="admin-nav-item"><i class="bi bi-house"></i> View Site</a>
    <a href="/admin/logout" class="admin-nav-item" style="color:var(--danger);"><i class="bi bi-box-arrow-right"></i> Logout</a>
  </nav>
</aside>

<div class="admin-main">
  <div class="admin-topbar">
    <h1 class="admin-page-title">Dashboard</h1>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
      <div class="admin-stat-card">
        <div class="admin-stat-icon" style="background:var(--accent-glow);color:var(--accent);"><i class="bi bi-people-fill"></i></div>
        <div class="admin-stat-info"><h3><%= stats.totalUsers %></h3><p>Total Users</p></div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="admin-stat-card">
        <div class="admin-stat-icon" style="background:#10b98122;color:var(--success);"><i class="bi bi-circle-fill" style="font-size:10px;"></i></div>
        <div class="admin-stat-info"><h3><%= stats.onlineUsers %></h3><p>Online Now</p></div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="admin-stat-card">
        <div class="admin-stat-icon" style="background:var(--accent2-glow);color:#a855f7;"><i class="bi bi-box-seam-fill"></i></div>
        <div class="admin-stat-info"><h3><%= stats.totalApis %></h3><p>Total APIs</p></div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="admin-stat-card">
        <div class="admin-stat-icon" style="background:#10b98122;color:var(--success);"><i class="bi bi-currency-rupee"></i></div>
        <div class="admin-stat-info"><h3>&#8377;<%= parseFloat(stats.totalDeposits).toFixed(0) %></h3><p>Total Deposits</p></div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="admin-stat-card">
        <div class="admin-stat-icon" style="background:#fbbf2422;color:var(--gold);"><i class="bi bi-graph-up-arrow"></i></div>
        <div class="admin-stat-info"><h3>&#8377;<%= parseFloat(stats.totalRevenue).toFixed(0) %></h3><p>Total Revenue</p></div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="admin-stat-card">
        <div class="admin-stat-icon" style="background:#f59e0b22;color:var(--warning);"><i class="bi bi-clock-fill"></i></div>
        <div class="admin-stat-info"><h3><%= stats.pendingDeposits %></h3><p>Pending Deposits</p></div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="admin-stat-card">
        <div class="admin-stat-icon" style="background:#00d4ff22;color:var(--accent);"><i class="bi bi-lightning-fill"></i></div>
        <div class="admin-stat-info"><h3><%= stats.pendingActivations %></h3><p>Pending Activations</p></div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="admin-stat-card">
        <div class="admin-stat-icon" style="background:#f472b622;color:#f472b6;"><i class="bi bi-chat-heart-fill"></i></div>
        <div class="admin-stat-info"><h3><%= stats.totalFeedback %></h3><p>Total Feedback</p></div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
