  </main>

  <!-- Footer -->
  <footer class="app-footer">
    <div class="footer-links">
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms & Conditions</a>
    </div>
    <div class="footer-social">
      <% if (siteSettings.telegram_link) { %><a href="<%= siteSettings.telegram_link %>" target="_blank"><i class="bi bi-telegram"></i></a><% } %>
      <% if (siteSettings.youtube_link) { %><a href="<%= siteSettings.youtube_link %>" target="_blank"><i class="bi bi-youtube"></i></a><% } %>
      <% if (siteSettings.whatsapp_link) { %><a href="<%= siteSettings.whatsapp_link %>" target="_blank"><i class="bi bi-whatsapp"></i></a><% } %>
      <% if (siteSettings.instagram_link) { %><a href="<%= siteSettings.instagram_link %>" target="_blank"><i class="bi bi-instagram"></i></a><% } %>
      <% if (siteSettings.facebook_link) { %><a href="<%= siteSettings.facebook_link %>" target="_blank"><i class="bi bi-facebook"></i></a><% } %>
      <% if (siteSettings.twitter_link) { %><a href="<%= siteSettings.twitter_link %>" target="_blank"><i class="bi bi-twitter-x"></i></a><% } %>
    </div>
    <div class="footer-copy">&copy; <%= new Date().getFullYear() %> <%= siteSettings.site_name || 'BR SUBODH YT' %>. All rights reserved.</div>
  </footer>

  <!-- Bottom Navigation -->
  <% if (currentUser) { %>
  <nav class="bottom-nav">
    <a href="/" class="nav-item <%= title === 'Home' ? 'active' : '' %>">
      <i class="bi bi-house-fill"></i><span>Home</span>
    </a>
    <a href="/deposit" class="nav-item <%= title === 'Deposit' ? 'active' : '' %>">
      <i class="bi bi-plus-circle-fill"></i><span>Deposit</span>
    </a>
    <a href="/api-history" class="nav-item <%= title === 'API History' ? 'active' : '' %>">
      <i class="bi bi-box-seam-fill"></i><span>APIs</span>
    </a>
    <a href="/transactions" class="nav-item <%= title === 'Transactions' ? 'active' : '' %>">
      <i class="bi bi-clock-history"></i><span>History</span>
    </a>
    <a href="/profile" class="nav-item <%= title === 'Profile' ? 'active' : '' %>">
      <i class="bi bi-person-fill"></i><span>Profile</span>
    </a>
  </nav>
  <% } %>

  <!-- Feedback Modal -->
  <% if (currentUser) { %>
  <div class="modal fade" id="feedbackModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content glass-card">
        <div class="modal-header border-0">
          <h5 class="modal-title"><i class="bi bi-chat-heart-fill me-2"></i>Leave Feedback</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="feedbackForm">
            <input type="hidden" name="ref_id" id="feedbackRefId">
            <input type="hidden" name="feedback_type" id="feedbackType">
            <div class="mb-3">
              <label class="form-label">Name</label>
              <input type="text" class="form-control form-input" name="name" value="<%= currentUser.full_name %>" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Rating</label>
              <div class="star-rating" id="starRating">
                <i class="bi bi-star-fill" data-value="1"></i>
                <i class="bi bi-star-fill" data-value="2"></i>
                <i class="bi bi-star-fill" data-value="3"></i>
                <i class="bi bi-star-fill" data-value="4"></i>
                <i class="bi bi-star-fill" data-value="5"></i>
              </div>
              <input type="hidden" name="rating" id="ratingValue" value="5">
            </div>
            <div class="mb-3">
              <label class="form-label">Feedback Message</label>
              <textarea class="form-control form-input" name="message" rows="3" placeholder="Share your experience..."></textarea>
            </div>
            <button type="submit" class="btn btn-accent w-100">Submit Feedback</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
