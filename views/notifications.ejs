<%- include('partials/head') %>

<div class="section-header">
  <h2 class="section-title"><i class="bi bi-bell me-2"></i>Notifications</h2>
</div>

<% if (notifications.length === 0) { %>
  <div class="empty-state"><i class="bi bi-bell-slash"></i><p>No notifications yet</p></div>
<% } else { %>
  <% notifications.forEach(n => { %>
  <div class="notif-item <%= !n.is_read ? 'unread' : '' %>">
    <div class="notif-icon" style="background:var(--accent-glow);color:var(--accent);"><i class="bi bi-bell-fill"></i></div>
    <div class="notif-content">
      <div class="notif-title"><%= n.title %></div>
      <div class="notif-message"><%= n.message %></div>
      <div class="notif-time"><%= new Date(n.created_at).toLocaleString('en-IN') %></div>
    </div>
  </div>
  <% }) %>
<% } %>

<%- include('partials/footer') %>
