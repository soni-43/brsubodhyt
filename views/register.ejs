<%- include('partials/head') %>

<div class="auth-container">
  <div class="auth-card">
    <div class="text-center mb-3">
      <div class="brand-icon mx-auto mb-3" style="width:56px;height:56px;font-size:28px;border-radius:16px;">
        <i class="bi bi-lightning-charge-fill"></i>
      </div>
    </div>
    <h1 class="auth-title">Create Account</h1>
    <p class="auth-subtitle">Join BR SUBODH YT today</p>
    
    <% if (error) { %>
      <div class="alert alert-danger py-2" style="font-size:13px;background:#ef444422;border-color:#ef444444;color:#ef4444;"><%= error %></div>
    <% } %>
    
    <% if (typeof step !== 'undefined' && step === 'otp') { %>
      <!-- OTP Step -->
      <form method="POST" action="/register">
        <input type="hidden" name="full_name" value="<%= typeof formData !== 'undefined' ? formData.full_name : '' %>">
        <input type="hidden" name="username" value="<%= typeof formData !== 'undefined' ? formData.username : '' %>">
        <input type="hidden" name="email" value="<%= typeof formData !== 'undefined' ? formData.email : '' %>">
        <input type="hidden" name="password" value="<%= typeof formData !== 'undefined' ? formData.password : '' %>">
        <input type="hidden" name="confirm_password" value="<%= typeof formData !== 'undefined' ? formData.confirm_password : '' %>">
        <input type="hidden" name="api_address" value="<%= typeof formData !== 'undefined' ? formData.api_address : '' %>">
        <input type="hidden" name="mobile" value="<%= typeof formData !== 'undefined' ? formData.mobile : '' %>">
        <div class="mb-3">
          <label class="form-label">OTP sent to <%= typeof formData !== 'undefined' ? formData.mobile : '' %></label>
          <input type="text" name="otp" class="form-control form-input" placeholder="Enter 6-digit OTP" maxlength="6" required>
        </div>
        <button type="submit" class="btn btn-accent w-100 mb-3">
          <i class="bi bi-shield-check me-2"></i>Verify & Create Account
        </button>
      </form>
    <% } else { %>
      <form id="registerForm">
        <div class="mb-3">
          <label class="form-label">Full Name</label>
          <input type="text" name="full_name" class="form-control form-input" placeholder="Enter your full name" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Username</label>
          <input type="text" name="username" class="form-control form-input" placeholder="Choose a username" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-control form-input" placeholder="Enter your email" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Mobile Number</label>
          <input type="tel" name="mobile" id="regMobile" class="form-control form-input" placeholder="10-digit mobile number" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control form-input" placeholder="Min 6 characters" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Confirm Password</label>
          <input type="password" name="confirm_password" class="form-control form-input" placeholder="Confirm password" required>
        </div>
        <div class="mb-3">
          <label class="form-label">API Address</label>
          <input type="text" name="api_address" class="form-control form-input" placeholder="Your API address (max 2 accounts)" required>
          <small style="color:var(--text-muted);font-size:11px;">Max 2 accounts per API address</small>
        </div>
        <div id="otpSection" style="display:none;">
          <div class="mb-3">
            <label class="form-label">OTP Verification</label>
            <div class="d-flex gap-2">
              <input type="text" name="otp" id="regOtp" class="form-control form-input" placeholder="Enter OTP" maxlength="6">
              <button type="button" class="btn btn-outline-accent" id="sendOtpBtn" style="white-space:nowrap;">Send OTP</button>
            </div>
            <div id="otpStatus" style="font-size:11px;margin-top:4px;"></div>
          </div>
        </div>
        <button type="submit" class="btn btn-accent w-100 mb-3" id="registerBtn">
          <i class="bi bi-person-plus me-2"></i>Create Account
        </button>
      </form>
    <% } %>
    
    <p class="text-center" style="font-size:13px;color:var(--text-secondary);">
      Already have an account? <a href="/login" style="color:var(--accent);">Login</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
