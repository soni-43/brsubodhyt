<%- include('partials/head') %>

<div class="profile-header">
  <div class="profile-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
  <h2 class="profile-name"><%= user.full_name %></h2>
  <p class="profile-username">@<%= user.username %></p>
</div>

<div class="profile-stats">
  <div class="profile-stat">
    <div class="profile-stat-value">&#8377;<%= parseFloat(user.balance).toFixed(0) %></div>
    <div class="profile-stat-label">Balance</div>
  </div>
  <div class="profile-stat">
    <div class="profile-stat-value">&#8377;<%= parseFloat(user.total_deposits).toFixed(0) %></div>
    <div class="profile-stat-label">Deposits</div>
  </div>
  <div class="profile-stat">
    <div class="profile-stat-value"><%= user.total_purchases %></div>
    <div class="profile-stat-label">Purchases</div>
  </div>
</div>

<!-- Feedback Buttons -->
<% if (depositsForFeedback.length > 0 || purchasesForFeedback.length > 0) { %>
<div class="glass-card mb-3" style="border-left:3px solid var(--gold);">
  <h6 style="font-family:var(--font-display);font-weight:600;margin-bottom:12px;"><i class="bi bi-chat-heart me-2"></i>Share Feedback</h6>
  <% depositsForFeedback.forEach(d => { %>
  <div class="d-flex justify-content-between align-items-center mb-2">
    <small style="color:var(--text-secondary);">Deposit #<%= d.id %> (₹<%= parseFloat(d.amount).toFixed(0) %>)</small>
    <button class="btn btn-sm btn-accent" onclick="openFeedbackModal(<%= d.id %>, 'deposit')">Feedback</button>
  </div>
  <% }) %>
  <% purchasesForFeedback.forEach(p => { %>
  <div class="d-flex justify-content-between align-items-center mb-2">
    <small style="color:var(--text-secondary);"><%= p.api_name %> (₹<%= parseFloat(p.price).toFixed(0) %>)</small>
    <button class="btn btn-sm btn-accent" onclick="openFeedbackModal(<%= p.id %>, 'purchase')">Feedback</button>
  </div>
  <% }) %>
</div>
<% } %>

<div class="glass-card mb-3">
  <h6 style="font-family:var(--font-display);font-weight:600;margin-bottom:12px;">Account Details</h6>
  <ul class="profile-info-list">
    <li><span>User ID</span><span>#<%= user.id %></span></li>
    <li><span>Username</span><span>@<%= user.username %></span></li>
    <li><span>Email</span><span><%= user.email %></span></li>
    <li><span>Mobile</span><span><%= user.mobile || 'N/A' %></span></li>
    <li><span>API Address</span><span><%= user.api_address %></span></li>
    <li><span>Join Date</span><span><%= new Date(user.created_at).toLocaleDateString('en-IN') %></span></li>
  </ul>
</div>

<a href="/logout" class="btn btn-outline-accent w-100" style="border-color:var(--danger);color:var(--danger);">
  <i class="bi bi-box-arrow-right me-2"></i>Logout
</a>

<%- include('partials/footer') %>
